; Poop Deck MQTT producer password (#13). Copy this file to poopdeck_secret.ini
; (gitignored — the repo is public, a committed secret is not a secret) and set the
; real value. This is MQTT_TINKLE_PASSWORD from Poop Deck's deploy/.env — the "tinkle"
; producer credential, issued out-of-band.
;
; A build made WITHOUT poopdeck_secret.ini omits the flag; the publisher then can't
; authenticate to the (auth-required) broker and simply never connects — harmless, just
; no telemetry. Override the broker host here too if bee-grace's LAN IP changes.
;
; NOTE: esp32_sim inherits this env; the sim has no network, so it's a no-op there.
[env:esp32]
build_flags =
    -D POOPDECK_MQTT_PASSWORD='"change-me"'
    ; -D POOPDECK_MQTT_HOST='"192.168.50.201"'   ; uncomment to override the default host
