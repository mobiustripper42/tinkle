; OTA shared secret (#126). Copy this file to ota_secret.ini (gitignored — the
; repo is public, a committed secret is not a secret) and change the value.
; The SPA's firmware-update control sends it as the X-OTA-Key header; a build
; made WITHOUT ota_secret.ini accepts OTA key-less (LAN-trusted per DEC-019).
;
; NOTE: esp32_sim overrides build_flags (TINKLE_SIM) and so drops the secret —
; intended: the sim has no OTA story.
[env:esp32]
build_flags = -D OTA_SECRET='"change-me"'
